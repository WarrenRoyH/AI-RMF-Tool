# AI-RMF Sentry Middleware Proxy Dockerfile
# Phase 12: Portability & Multi-Platform Validation

# Use a Python base image
FROM python:3.11-slim

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Install uv for fast dependency management
COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/

# Set working directory
WORKDIR /app

# Copy dependency files first for better caching
COPY pyproject.toml uv.lock ./

# Install standard (llm-guard) and middleware (proxy) extras
RUN uv sync --frozen --no-dev --extra standard --extra middleware

# Pre-download NLP models for Sentry (llm-guard)
RUN uv run python3 -m spacy download en_core_web_lg --quiet

# Copy core logic and necessary directories
COPY core/ core/
COPY librarian/ librarian/
COPY config/ config/
# Create workspace directory structure
RUN mkdir -p workspace/logs workspace/reports workspace/policies

# Set default environment variables
ENV PYTHONPATH=.
ENV AI_RMF_PROXY_HOST=0.0.0.0
ENV AI_RMF_PROXY_PORT=8080
ENV PHOENIX_PORT=6006
ENV PHOENIX_PROJECT_NAME=ai-rmf-tools

# Expose the proxy port
EXPOSE 8080

# The proxy will use workspace/project-manifest.json for policy enforcement.
# This should be mounted as a volume or copied if static.
# For portability, we don't copy it here to ensure it uses the latest local version.

# Run the proxy
CMD ["uv", "run", "core/proxy.py"]
