#!/bin/sh

# AI-RMF Lifecycle Launcher
# Goal: Ensure the virtualenv is active before running the Python core.

set -e

# Get the directory where the script is located
BASE_DIR="$(cd "$(dirname "$0")" && pwd)"

# Ensure we use the full path to uv
UV_PATH="/home/warren/.local/bin/uv"

if [ ! -f "$UV_PATH" ]; then
    echo "Error: uv not found. Run './bootstrap.sh' first."
    exit 1
fi

exec "$UV_PATH" run python3 "$BASE_DIR/ai_rmf_core.py" "$@"
